generator client {
  provider = "prisma-client"
  output   = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
   id String @id @default(nanoid())
   accountId String @unique @map("account_id")

   name String?
   avatar String?

   createdAt DateTime @default(now()) @map("created_at")
   updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
